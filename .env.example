PROJECT_NAME=Opposing Counsel Simulator
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/opposing_counsel
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=opposing_counsel_evidence
FILE_STORAGE_ROOT=/app/storage
UPLOAD_MAX_MB=25
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
USE_RULE_BASED_AI_FALLBACK=true
LOG_LEVEL=INFO
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
